# Copia este archivo a .env y ajusta los valores
POSTGRES_USER=idp
POSTGRES_PASSWORD=idp
POSTGRES_DB=idp

# Idiomas de Tesseract (instalados en la imagen del backend)
OCR_LANGS=spa+eng

# Modelo LLM para generacion (sugerir campos)
# En local: qwen2.5:7b-instruct (mejor calidad) o qwen2.5:3b-instruct (mas rapido)
# En el server remoto (ver abajo): llama3.1:8b
OLLAMA_MODEL=llama3.1:8b

# Backend de GENERACION remoto opcional (embeddings siguen en el Ollama local).
# Dejar OLLAMA_GEN_URL vacio = toda la generacion en local.
OLLAMA_GEN_URL=
OLLAMA_GEN_API_KEY=
